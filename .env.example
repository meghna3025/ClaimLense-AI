GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_VISION_MODEL=gemini-1.5-pro

# FAISS index base directory
CHROMA_PERSIST_DIR=./rag/faiss_db

# RAG source paths
RAG_POLICIES_DIR=./rag/policies
RAG_REPAIR_DIR=./rag/repair_catalog
RAG_FRAUD_DIR=./rag/fraud_rules
RAG_CLAIMS_DIR=./rag/claims_history

# App
APP_ENV=development
LOG_LEVEL=INFO
